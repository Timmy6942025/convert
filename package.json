{
  "name": "fconvert",
  "version": "0.1.8",
  "description": "Fast local CLI conversion tool with graph-based anything-to-anything routing",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "bun run src/cli/main.ts",
    "convert": "bun run src/cli/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:cli": "bun build src/cli/main.ts --target=node --outfile dist/main.js",
    "build:picker": "go build -C tools/format-picker -o ../../dist/fconvert-picker .",
    "build": "bun run build:cli && bun run build:picker",
    "prepack": "npm run build"
  },
  "bin": {
    "fconvert": "bin/fconvert.js",
    "convert": "bin/fconvert.js"
  },
  "files": [
    "bin/",
    "dist/main.js",
    "dist/fconvert-picker",
    "assets/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "convert",
    "converter",
    "ffmpeg",
    "pandoc",
    "cli"
  ],
  "license": "MIT"
}
